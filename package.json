{
  "name": "webintel-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "doctor": "node scripts/local-doctor.mjs",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:push": "prisma db push",
    "db:setup": "npm run prisma:generate && npm run db:push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "scraper:install": "python3 -m pip install -r scraper_service/requirements.txt && python3 -m playwright install chromium",
    "scraper:dev": "python3 -m uvicorn scraper_service.app.main:app --host 127.0.0.1 --port 8001",
    "scraper:watch": "python3 -m uvicorn scraper_service.app.main:app --reload --host 127.0.0.1 --port 8001",
    "dev:all": "concurrently -k -n web,scraper -c blue,green \"npm run dev\" \"npm run scraper:dev\""
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@react-pdf/renderer": "4.5.1",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.38.0",
    "jose": "6.2.3",
    "lucide-react": "1.11.0",
    "nanoid": "5.1.9",
    "next": "16.2.4",
    "openai": "6.34.0",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.74.0",
    "recharts": "3.8.1",
    "slugify": "1.6.9",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/bcryptjs": "3.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "prisma": "7.8.0",
    "tailwindcss": "4.2.4",
    "typescript": "^5.9.3"
  }
}
